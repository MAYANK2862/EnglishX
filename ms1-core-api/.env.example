PORT=3001
NODE_ENV=development

# Database (Neon PostgreSQL - sign up at neon.tech when ready)
DATABASE_URL=postgresql://user:password@localhost:5432/englishx

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Resend Email (sign up at resend.com when ready)
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=onboarding@resend.dev

# ms2 Speech Agent URL
MS2_BASE_URL=http://localhost:8000

# Frontend URL (for CORS and invite links)
FRONTEND_URL=http://localhost:3000

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ms1-core-api
